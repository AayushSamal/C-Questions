#include <stdio.h>

int main()
{
    int n, i, max;

    printf("Enter the max number of elements in an array: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter the elements of the array: ");
    for (i = 0; i<= n; i++)
    {
        scanf("%d", &arr[i]);
    }
    
    max = arr[0];

    for (i= 0; i < n; i++)
    {
        if(arr[i] > max)
        {
            max = arr[i];
        }
    }
    
    printf("The greatest number is: %d", max );

    return 0;
}
