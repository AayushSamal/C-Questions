    char str[nChar + 1];

    printf("Enter the string: ");
    scanf("%s", &str);

    for(int i = 0; i<=nChar+1; i++)
    {
        if (str[i]== 'a' || str[i]== 'e' || str[i]== 'i' || str[i]== 'o' || str[i]== 'u' || str[i]== 'A' || str[i]== 'E' || str[i]== 'I' || str[i]== 'O' || str[i]== 'U')
        {
            countVowel++;
        }
        
    }

    printf("The number of vowels: %d", countVowel);
    
    return 0;
}
