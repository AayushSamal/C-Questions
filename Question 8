#include <stdio.h>

int main()
{
    int a,b;
    printf("Enter two numbers: ");
    scanf("%d %d",&a, &b);

    if (a > b)
    {
        printf("The bigger number is %d", a);
    }
    else if (a < b)
    {
        printf("The bigger number is %d", b);
    }
    else
    {
        printf("Both are equal");
    }
    
    return 0;
}
