#include <stdio.h>

int main()
{
    int n, sum = 0;
    printf("Enter the number of elements in the array: ");
    scanf("%d", &n);

    int arr[n-1];
    printf("Enter the elements in the array: ");
    for (int i = 0; i <= n-1; i++)
    {
        scanf("%d", &arr[i]);
    }
    for (int i = 0; i < n; i++)
    {
        sum = sum + arr[i];
    }

    printf("The sum is: %d", sum);

    return 0;
}
