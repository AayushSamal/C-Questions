#include <stdio.h>

int main()
{
    int n, i, isPrime  = 0;

    printf("Enter a number: ");
    scanf("%d", &n);

    for (i = 1; i <= n ; i++)
    {
        if (n % i == 0)
        {
           isPrime++ ;
        }
        
    }
    if (isPrime == 2)
    {
        printf("This is a prime number.\n");
    }
    else
    {
        printf("This is not a prime number.\n");
    }
    
    
    return 0;
}
